# ============================================================
# WeWrite 环境变量配置
# 本地开发：复制此文件为 .env.local，填入真实值
# Vercel 部署：在 Project Settings → Environment Variables 中添加以下变量
# ============================================================

# 豆包 Vision API Key（火山引擎方舟平台）
# 获取地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
DOUBAO_API_KEY=

# Claude API Key（Anthropic，当前版本暂未启用，留空即可）
# 获取地址：https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=
